# Copy this file to secrets.yaml and fill in your values
# secrets.yaml is gitignored and will not be committed

# Your Wi-Fi SSID and password
wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"

# Home Assistant API encryption key (generate with: esphome wizard)
api_encryption_key: "your_base64_api_encryption_key"

# Victron BLE credentials (from Victron Connect app)
victron_shunt_mac: "AA:BB:CC:DD:EE:FF"
victron_shunt_bindkey: "00000000000000000000000000000000"
victron_mppt_mac: "AA:BB:CC:DD:EE:FF"
victron_mppt_bindkey: "00000000000000000000000000000000"
victron_charger_mac: "AA:BB:CC:DD:EE:FF"
victron_charger_bindkey: "00000000000000000000000000000000"

# ThermoPro BLE MACs (from BLE scanner app)
thermopro_tp357_mac: "AA:BB:CC:DD:EE:FF"
thermopro_tp351a_mac: "AA:BB:CC:DD:EE:FF"
thermopro_tp351b_mac: "AA:BB:CC:DD:EE:FF"

# BM6 Starter Battery Monitor (waveshare-175.yaml only)
bm6_mac: "AA:BB:CC:DD:EE:FF"
